PORT=3000
NODE_ENV=development

# Frontend permitido pelo CORS.
# Use * para permitir todos, ou virgula para varios dominios.
CORS_ORIGIN=*

# Gere outro valor para producao.
JWT_SECRET=troque-por-uma-chave-grande-e-aleatoria
JWT_EXPIRES_IN_SECONDS=86400

# Preferido no Render: use a connection string do Supabase Pooler.
# DATABASE_URL=postgresql://postgres.xwnkbpluxftynawtajay:SUA_PASSWORD_URL_ENCODED@aws-0-eu-west-3.pooler.supabase.com:5432/postgres
DB_SSL=true
DB_POOL_MAX=5

# Alternativa para ambiente local ou se nao usar DATABASE_URL.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ai2
DB_USER=postgres
DB_PASSWORD=postgres
